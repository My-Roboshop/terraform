# Local .terraform directories (contains provider binaries and modules)
.terraform/

# .tfstate files (Contains sensitive data; use a remote backend instead)
*.tfstate
*.tfstate.*
*.tfstate.*backup
*.tfplan

# Crash log files
crash.log
crash.*.log

# Exclude all .tfvars files (Likely contain sensitive data/secrets)
*.tfvars
*.tfvars.json

# Ignore override files
override.tf
override.tf.json
*_override.tf
*_override.tf.json

# Ignore temporary lock info files
.terraform.tfstate.lock.info

# Include .terraform.lock.hcl (Recommended to track provider versions)
.terraform.lock.hcl
